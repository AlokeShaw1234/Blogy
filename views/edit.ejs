<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>edit Posts</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>
    <h2>Edit your post</h2>
    <h4>Post id : <%= post.id %> </h4>
    <h4>Post username : <%= post.username %> </h4>
    <form method="post" action="/posts/<%=post.id%>?_method=PATCH">  <!--overriding post to patch request using method-override package-->
        <textarea rows="10" cols="40" name="content"> <%= post.content %></textarea>
        <br>
        <br>
        <button>Commit Changes</button>
    </form>
</body>
</html>